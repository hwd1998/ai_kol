# 简体中文注释：复制本文件为 .env，并按实际环境填写

# 服务端口
PORT=3000

# 数据库配置（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=hwd19981214
DB_NAME=creatorhub_db

# TypeORM 配置
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT 配置（务必使用强随机密钥）
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# 初始化管理员（init:admin 脚本）
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@creatorhub.local
INIT_ADMIN_PASSWORD=admin123456
